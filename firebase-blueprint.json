{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and credit balance",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "credits": { "type": "integer", "description": "Remaining credits for document generation" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "credits", "createdAt"]
    },
    "Generation": {
      "title": "Generation",
      "description": "A record of a document generation",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "type": { "type": "string", "enum": ["ppt", "pdf", "word"] },
        "prompt": { "type": "string" },
        "title": { "type": "string" },
        "content": { "type": "string", "description": "JSON string or markdown content generated by AI" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "type", "prompt", "title", "content", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile data"
    },
    "/generations/{genId}": {
      "schema": "Generation",
      "description": "History of generated documents"
    }
  }
}
